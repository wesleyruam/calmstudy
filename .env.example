# Copie para .env e ajuste. Nunca comite o .env real.

# Banco (Postgres do docker-compose — porta 5433 no host)
DATABASE_URL="postgresql://calmstudy:calmstudy@localhost:5433/calmstudy?schema=public"

# Fila / cache (Redis do docker-compose — porta 6380 no host)
REDIS_URL="redis://localhost:6380"

# Storage de arquivos no dev (filesystem). Em prod: MinIO/S3.
# IMPORTANTE: caminho ABSOLUTO — web e worker rodam em CWDs diferentes e precisam
# apontar para a mesma pasta. Ex: /caminho/para/CalmStudy/storage
STORAGE_DIR="/ABSOLUTE/PATH/TO/CalmStudy/storage"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET="troque-isto"

# IA (opt-in). Deixe vazio para desligar recursos de IA.
ANTHROPIC_API_KEY=""
VOYAGE_API_KEY=""
