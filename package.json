{
  "name": "calmstudy",
  "version": "0.0.0",
  "private": true,
  "description": "Biblioteca digital pessoal — leitura, estudo e organização.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @calmstudy/db generate",
    "db:migrate": "pnpm --filter @calmstudy/db migrate",
    "db:studio": "pnpm --filter @calmstudy/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "msgpackr-extract"
    ],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
