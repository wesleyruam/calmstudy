// CalmStudy — schema Prisma. Mapeia docs/DATA-MODEL.md.
// Fase 1: User, Book, UserBook + organização (Shelf/Collection/Tag) + marcações.
// Fase 5 adiciona Embedding (pgvector). Veja docs/ROADMAP.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum BookFormat {
  PDF
  EPUB
  MOBI
  CBZ
  CBR
  TXT
  MD
  DOCX
  HTML
}

enum BookStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum ReadingStatus {
  WANT_TO_READ
  READING
  FINISHED
  PAUSED
}

enum Priority {
  LOW
  MED
  HIGH
}

// Categorias de estudo (módulo 1). Cada uma tem uma cor padrão no cliente;
// Highlight.color pode sobrescrever com um hex personalizado.
enum HighlightCategory {
  IMPORTANT // 🟨 Importante
  DEFINITION // 🟩 Definição
  EXAMPLE // 🟦 Exemplo
  QUESTION // 🟥 Dúvida
  REVIEW // 🟪 Revisar
  EXERCISE // 🟧 Exercício
  QUOTE // ⚪ Citação
  IDEA // 🔵 Ideia
  APPLICATION // 🟫 Aplicação prática
}

// Status de revisão de um destaque/nota (módulos 13 e 24).
enum ReviewStatus {
  NONE
  PENDING
  REVIEWED
  MASTERED
}

// ───────────────────────────── Núcleo ─────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String?
  image        String?
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())

  userBooks   UserBook[]
  shelves     Shelf[]
  collections Collection[]
  tags        Tag[]
  notes       Note[]
  concepts    Concept[]

  ownedSpaces      StudySpace[]   @relation("SpaceOwner")
  spaceMemberships SpaceMember[]
  invitesCreated   SpaceInvite[]  @relation("InviteCreator")
  contributions    Contribution[] @relation("ContribAuthor")
}

// O documento em si (fato objetivo, deduplicável entre usuários).
model Book {
  id          String     @id @default(uuid())
  title       String
  author      String?
  description String?
  coverUrl    String?
  isbn        String?
  language    String?
  pages       Int?
  format      BookFormat
  fileKey     String // chave no StorageProvider (FS/MinIO)
  fileSize    BigInt
  contentHash String? // sha256 do arquivo — dedup e casamento de edição (Espaços de Estudo)
  status      BookStatus @default(UPLOADING)
  metadata    Json       @default("{}") // ano, editora, categorias, específicos do formato
  textContent String? // texto extraído (FTS) — mover p/ tabela à parte se crescer
  createdAt   DateTime   @default(now())

  // Coluna gerada (STORED) mantida pelo Postgres — ver migration search_fts.
  searchTsv Unsupported("tsvector")? @map("search_tsv")

  userBooks     UserBook[]
  spaces        StudySpace[]
  contributions Contribution[]

  @@index([isbn])
  @@index([contentHash])
  @@index([searchTsv], type: Gin)
}

// ─────────────────────── Espaços de Estudo (colaboração) ───────────────────────
// Camada colaborativa: ver docs/STUDY-SPACES.md. Princípio nº 0 — nada é
// compartilhado sem ação explícita; a camada compartilhada é separada do pessoal.

enum SpaceRole {
  OWNER
  MODERATOR
  MEMBER
  VIEWER
}

enum SpaceVisibility {
  PRIVATE
  PUBLIC
}

enum SpaceFileSharing {
  HASH_MATCH // cada membro tem sua cópia; casa por contentHash (sem redistribuir)
  SHARED_FILE // o espaço compartilha o arquivo (docs próprios/domínio público)
}

model StudySpace {
  id          String           @id @default(uuid())
  name        String
  description String?
  ownerId     String
  bookId      String
  visibility  SpaceVisibility  @default(PRIVATE)
  fileSharing SpaceFileSharing @default(SHARED_FILE)
  createdAt   DateTime         @default(now())

  owner User @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  book  Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  members       SpaceMember[]
  invites       SpaceInvite[]
  objectives    SpaceObjective[]
  contributions Contribution[]
  artifacts     SpaceArtifact[]

  @@index([ownerId])
  @@index([bookId])
}

model SpaceMember {
  id            String    @id @default(uuid())
  spaceId       String
  userId        String
  role          SpaceRole @default(MEMBER)
  shareProgress Boolean   @default(false) // consentimento p/ progresso coletivo
  joinedAt      DateTime  @default(now())

  space StudySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId])
}

model SpaceInvite {
  id          String    @id @default(uuid())
  spaceId     String
  code        String    @unique
  role        SpaceRole @default(MEMBER)
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  space     StudySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy User       @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
}

model SpaceObjective {
  id        String   @id @default(uuid())
  spaceId   String
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  space StudySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

// Contribuição na camada compartilhada (Fase 2): discussão/pergunta/comentário
// ancorada no material. Sempre nasce por ação explícita — o pessoal fica separado.
enum ContributionKind {
  QUESTION
  COMMENT
  ANSWER
  NOTE
}

enum ContributionAnchor {
  BOOK
  CHAPTER
  PAGE
  RANGE
  CONCEPT
}

enum ContributionVisibility {
  SPACE
  PUBLIC
}

model Contribution {
  id          String                 @id @default(uuid())
  spaceId     String
  authorId    String
  bookId      String
  kind        ContributionKind
  anchorType  ContributionAnchor     @default(PAGE)
  page        Int? // desnormalizado da âncora p/ filtrar rápido por página
  quotedText  String? // trecho citado (RANGE) — legível mesmo se o render mudar
  content     Json
  contentText String
  parentId    String? // resposta dentro de uma thread
  visibility  ContributionVisibility @default(SPACE)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?

  space   StudySpace           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author  User                 @relation("ContribAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  book    Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent  Contribution?        @relation("ContribThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Contribution[]       @relation("ContribThread")
  reports ContributionReport[]

  @@index([spaceId, page])
  @@index([parentId])
  @@index([bookId, page, visibility]) // camada da comunidade (público por livro+página)
}

// Denúncia de contribuição (moderação, Fase 4). Um usuário denuncia uma vez.
model ContributionReport {
  id             String   @id @default(uuid())
  contributionId String
  reporterId     String
  reason         String?
  createdAt      DateTime @default(now())

  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@unique([contributionId, reporterId])
  @@index([contributionId])
}

// Artefatos colaborativos do espaço (Fase 3): documentos co-editáveis por
// qualquer membro, com histórico de versões e atribuição.
enum ArtifactType {
  SUMMARY // resumo por capítulo
  GLOSSARY // termo do glossário
  CONCEPT // conceito importante
  REFERENCE // referência externa
  EXERCISE // exercício
}

model SpaceArtifact {
  id          String       @id @default(uuid())
  spaceId     String
  type        ArtifactType
  title       String // capítulo/termo/título
  anchor      Json? // { chapter?, page?, url? } — opcional
  content     Json
  contentText String
  createdById String
  updatedById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  space     StudySpace         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  revisions ArtifactRevision[]

  @@index([spaceId, type])
}

model ArtifactRevision {
  id          String   @id @default(uuid())
  artifactId  String
  editedById  String
  title       String
  contentText String
  content     Json
  editedAt    DateTime @default(now())

  artifact SpaceArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
}

// A relação do usuário com o livro (estado pessoal + preferências de leitura).
model UserBook {
  id       String @id @default(uuid())
  userId   String
  bookId   String

  status   ReadingStatus @default(WANT_TO_READ)
  progress Float         @default(0)
  favorite Boolean       @default(false)
  rating   Int?
  priority Priority?
  color    String?

  lastPage   Int       @default(0)
  lastReadAt DateTime?

  // preferências de leitura sincronizadas
  theme     String?
  viewMode  String?
  font      String?
  fontSize  Int?
  lineHeight Float?
  zoom      Float?
  prefs     Json   @default("{}")

  deletedAt DateTime? // soft-delete (lixeira)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  shelves     UserBookShelf[]
  collections UserBookCollection[]
  tags        UserBookTag[]
  highlights  Highlight[]
  notes       Note[]
  bookmarks   Bookmark[]
  stickers    Sticker[]
  concepts    ConceptBook[]
  summaries   Summary[]
  sessions    StudySession[]
  goals       Goal[]
  tasks       BookTask[]
  pageLinks   PageLink[]

  @@unique([userId, bookId])
  @@index([userId, status])
}

// Referência cruzada rotulada entre duas páginas do mesmo livro (leitor, aba Links).
model PageLink {
  id         String @id @default(uuid())
  userBookId String
  fromPage   Int
  toPage     Int
  label      String

  createdAt DateTime @default(now())

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId, fromPage])
}

// ──────────────────────────── Organização ────────────────────────────

model Shelf {
  id     String  @id @default(uuid())
  userId String
  name   String
  color  String?
  icon   String?

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  books UserBookShelf[]
}

model Collection {
  id          String  @id @default(uuid())
  userId      String
  name        String
  description String?

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  books UserBookCollection[]
}

// Tag universal (módulo 6): serve qualquer entidade via junções dedicadas.
model Tag {
  id     String  @id @default(uuid())
  userId String
  name   String
  color  String?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  books      UserBookTag[]
  highlights HighlightTag[]
  notes      NoteTag[]
  concepts   ConceptTag[]

  @@unique([userId, name])
}

model UserBookShelf {
  userBookId String
  shelfId    String

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  shelf    Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@id([userBookId, shelfId])
}

model UserBookCollection {
  userBookId   String
  collectionId String

  userBook   UserBook   @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userBookId, collectionId])
}

model UserBookTag {
  userBookId String
  tagId      String

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userBookId, tagId])
}

// ──────────────────────────── Marcações ────────────────────────────
// Âncoras resilientes (textRange/CFI/rects normalizados) em Json — ver ARCHITECTURE §5.

// Highlight rico (módulo 1): cada destaque é uma entidade de estudo.
model Highlight {
  id           String            @id @default(uuid())
  userBookId   String
  page         Int?
  chapter      String? // capítulo/seção, quando conhecido
  category     HighlightCategory @default(IMPORTANT)
  color        String? // hex personalizado; null = cor da categoria
  text         String // trecho destacado
  observation  String? // observação rápida (módulo 1)
  anchor       Json // âncora resiliente: page + rects normalizados
  priority     Priority?
  favorite     Boolean           @default(false)
  reviewStatus ReviewStatus      @default(NONE)
  // Repetição espaçada (E5, módulo 24): agenda de revisão.
  reviewCount    Int       @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  searchTsv Unsupported("tsvector")? @map("search_tsv")

  userBook UserBook           @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  notes    Note[]
  tags     HighlightTag[]
  concepts ConceptHighlight[]

  @@index([userBookId])
  @@index([userBookId, category])
  @@index([userBookId, reviewStatus])
  @@index([searchTsv], type: Gin)
}

enum NoteKind {
  NOTE
  QUESTION
}

// Nota Rich Text (módulo 2) — corpo em JSON (TipTap). Pode estar:
//  - ancorada a um highlight (highlightId),
//  - ligada a um livro sem highlight (userBookId, ex. resumo/marginalia),
//  - ou solta como página livre do usuário (isFreePage, módulo 5).
model Note {
  id          String   @id @default(uuid())
  userId      String
  userBookId  String?
  highlightId String?
  conceptId   String?
  page        Int?
  position    Json? // {x,y} fração da página (marginalia)
  kind        NoteKind @default(NOTE) // nota livre ou pergunta (leitor, painel da página)
  title       String?
  content     Json     @default("{}") // documento TipTap (JSON)
  contentText String? // projeção texto puro p/ busca (FTS)
  isFreePage  Boolean  @default(false)
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  searchTsv Unsupported("tsvector")? @map("search_tsv")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userBook  UserBook?  @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  highlight Highlight? @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  concept   Concept?   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  tags      NoteTag[]

  @@index([userId])
  @@index([userBookId])
  @@index([highlightId])
  @@index([conceptId])
  @@index([searchTsv], type: Gin)
}

// ── Junções de tag (módulo 6) ──
model HighlightTag {
  highlightId String
  tagId       String

  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([highlightId, tagId])
}

model NoteTag {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model Bookmark {
  id          String  @id @default(uuid())
  userBookId  String
  page        Int
  title       String?
  description String?
  color       String?
  category    String?

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
}

model Sticker {
  id         String @id @default(uuid())
  userBookId String
  page       Int
  x          Float
  y          Float
  rotation   Float  @default(0)
  scale      Float  @default(1)
  type       String

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
}

// ─────────────────────── Base de conhecimento (E3) ───────────────────────

// Conceito (módulo 7): entidade de conhecimento independente do livro.
model Concept {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String? // definição curta
  content     Json     @default("{}") // corpo Rich Text (TipTap)
  contentText String? // projeção texto puro p/ busca
  color       String?
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  searchTsv Unsupported("tsvector")? @map("search_tsv")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags       ConceptTag[]
  books      ConceptBook[]
  highlights ConceptHighlight[]
  notes      Note[]
  linksFrom  ConceptLink[]      @relation("linkFrom")
  linksTo    ConceptLink[]      @relation("linkTo")

  @@unique([userId, title])
  @@index([userId])
  @@index([searchTsv], type: Gin)
}

// Link entre conceitos (módulo 8): a aresta da wiki pessoal.
model ConceptLink {
  id     String  @id @default(uuid())
  fromId String
  toId   String
  label  String? // "relaciona-se com", "depende de"…

  from Concept @relation("linkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Concept @relation("linkTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([toId])
}

// Conceito ↔ livro relacionado.
model ConceptBook {
  conceptId  String
  userBookId String

  concept  Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@id([conceptId, userBookId])
}

// Conceito ↔ destaque (evidência do conceito num livro).
model ConceptHighlight {
  conceptId   String
  highlightId String

  concept   Concept   @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@id([conceptId, highlightId])
}

model ConceptTag {
  conceptId String
  tagId     String

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conceptId, tagId])
}

// ─────────────────────────── Métricas (E4) ───────────────────────────

// Sessão de estudo (módulo 11): uma janela de leitura com tempo ativo e páginas.
model StudySession {
  id         String    @id @default(uuid())
  userBookId String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  seconds    Int       @default(0) // tempo ativo acumulado
  startPage  Int?
  endPage    Int?

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
  @@index([startedAt])
}

// Objetivo de estudo (módulo 15): meta com alvo opcional.
model Goal {
  id         String   @id @default(uuid())
  userBookId String
  title      String
  kind       String   @default("CUSTOM") // PAGES | MINUTES | CHAPTER | CUSTOM
  target     Int?
  done       Boolean  @default(false)
  createdAt  DateTime @default(now())

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
}

// Checklist de estudos (módulo 16): tarefas simples por livro.
model BookTask {
  id         String   @id @default(uuid())
  userBookId String
  title      String
  done       Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
}

// Resumo por capítulo (módulo 9): resumo/ideias/aprendizados de uma parte do livro.
model Summary {
  id          String   @id @default(uuid())
  userBookId  String
  chapter     String?
  title       String?
  content     Json     @default("{}") // Rich Text (TipTap)
  contentText String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  searchTsv Unsupported("tsvector")? @map("search_tsv")

  userBook UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId])
  @@index([searchTsv], type: Gin)
}
